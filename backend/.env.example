# =============================================================================
# Authly · Backend environment template
# =============================================================================
# Copy this file to backend/.env and fill in real values.
#   cp backend/.env.example backend/.env
#
# This template is committed to git; backend/.env is NOT and never should be.
# Generate fresh JWT_SECRET and REFRESH_SECRET values with:
#   cd backend && npm run gen-secrets
# =============================================================================


# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# development | production. Controls cookie security (Secure + SameSite=None
# in production, lax + non-secure in dev), morgan request logging, and other
# environment-aware behaviour.
NODE_ENV=development

# Port the HTTP server listens on. Render and most PaaS providers will inject
# their own PORT; the code reads it from process.env.PORT either way.
PORT=5000

# Brand name shown in transactional email subjects and bodies, plus the
# health endpoint and (optionally) the SPA navbar.
APP_NAME=Authly


# -----------------------------------------------------------------------------
# Frontend origin
# -----------------------------------------------------------------------------
# Used for two things:
#   1. The CORS allowlist (only this exact origin can hit the API with cookies).
#   2. The base URL used when generating verification and reset links emailed
#      to users.
# In production this is the Vercel URL (or your custom domain).
# Must include the scheme. Must NOT have a trailing slash.
FRONTEND_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
# Either a local mongod or an Atlas cluster. The username and password go
# inside the URI; URL-encode the password if it contains @ : / ? # & %.
# Atlas free tier (M0) is enough for this project.
#
# Local example:    mongodb://localhost:27017/authly
# Atlas example:    mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<name>
MONGODB_URI=mongodb://localhost:27017/authly


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Use rediss:// (two s) for TLS-enabled hosted providers like Upstash.
# Use redis:// for a local redis-server.
#
# Local example:    redis://localhost:6379
# Upstash example:  rediss://default:<token>@<subdomain>.upstash.io:6379
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# SMTP (Gmail in dev; switch to Resend or SES in production)
# -----------------------------------------------------------------------------
# SMTP_USER is the From address.
# SMTP_PASS is a Gmail App Password (NOT your account password). Generate at:
#   https://myaccount.google.com/apppasswords  (requires 2-Step Verification)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-gmail-app-password


# -----------------------------------------------------------------------------
# JWT secrets
# -----------------------------------------------------------------------------
# Both must be 64-byte cryptographically random hex strings.
# JWT_SECRET signs the 15-minute access token.
# REFRESH_SECRET signs the 7-day refresh token.
# They must be DIFFERENT from each other so a leak of one does not compromise
# the other token class.
#
# Generate with:  cd backend && npm run gen-secrets
# Never commit the real values. Never reuse dev values in production.
JWT_SECRET=replace-me-with-64-bytes-of-hex-from-gen-secrets
REFRESH_SECRET=replace-me-with-a-different-64-bytes-of-hex
