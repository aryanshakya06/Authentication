# =============================================================================
# Authly · Backend environment template
# =============================================================================
# Copy this file to backend/.env and fill in real values.
#   cp backend/.env.example backend/.env
#
# This template is committed to git. backend/.env is NOT and never should be.
# Generate fresh JWT_SECRET and REFRESH_SECRET values with:
#   cd backend && npm run gen-secrets
# =============================================================================


# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# development | production. Controls cookie security (Secure + SameSite=None
# in production, lax + non-secure in dev), morgan log format, and other
# environment-aware behaviour.
NODE_ENV=development

# Port the HTTP server listens on. Render and most PaaS providers will inject
# their own PORT. The code reads it from process.env.PORT either way.
PORT=5000

# Brand name shown in transactional email subjects and bodies, plus the
# health endpoint and (optionally) the SPA navbar.
APP_NAME=Authly

# Number of reverse proxies the app sits behind. Render and most PaaS = 1.
# This is what 'trust proxy' is set to so req.ip and rate limiters work.
TRUST_PROXY=1


# -----------------------------------------------------------------------------
# Frontend origin (CORS allowlist + base for verify/reset email links)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins. The first entry is treated as the
# canonical origin and used to build the URLs in transactional emails. The
# rest (if any) are simply allowed through CORS, which is useful for Vercel
# preview deployments.
#
# Local example:    http://localhost:5173
# Prod example:     https://app.example.com
# Prod + preview:   https://app.example.com,https://app-git-feat.vercel.app
FRONTEND_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# Cookies (production only)
# -----------------------------------------------------------------------------
# Optional. If your API runs at api.example.com and your SPA at
# app.example.com, set this to ".example.com" so the cookies set by the API
# also flow on cross-subdomain requests. Leave EMPTY for local development
# and for split-host setups (api.onrender.com + app.vercel.app).
COOKIE_DOMAIN=


# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
# Either a local mongod or an Atlas cluster. The username and password go
# inside the URI. URL-encode the password if it contains @ : / ? # & %.
# Atlas free tier (M0) is enough for this project.
#
# Local example:    mongodb://localhost:27017/authly
# Atlas example:    mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<name>
MONGODB_URI=mongodb://localhost:27017/authly


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Use rediss:// (two s) for TLS-enabled hosted providers like Upstash.
# Use redis:// for a local redis-server.
#
# Local example:    redis://localhost:6379
# Upstash example:  rediss://default:<token>@<subdomain>.upstash.io:6379
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# SMTP
# -----------------------------------------------------------------------------
# Defaults below assume Gmail with an App Password (requires 2-Step Verification
# at https://myaccount.google.com/apppasswords ). For production with custom
# domain sending, switch to Resend / SES / Postmark and override SMTP_HOST etc.
#
# Resend example:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=<your resend api key>
#   SMTP_FROM=no-reply@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
# Optional. The "From" address. Defaults to SMTP_USER.
SMTP_FROM=


# -----------------------------------------------------------------------------
# JWT secrets
# -----------------------------------------------------------------------------
# Both must be 64-byte cryptographically random hex strings.
# JWT_SECRET signs the 15-minute access token.
# REFRESH_SECRET signs the 7-day refresh token.
# They must be DIFFERENT from each other so a leak of one does not compromise
# the other token class. The bootstrap will fail fast if they match.
#
# Generate with:  cd backend && npm run gen-secrets
# Never commit the real values. Never reuse dev values in production.
JWT_SECRET=replace-me-with-64-bytes-of-hex-from-gen-secrets
REFRESH_SECRET=replace-me-with-a-different-64-bytes-of-hex
