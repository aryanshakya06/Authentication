# --- Server ---
NODE_ENV=development
PORT=5000
APP_NAME=Authly

# --- Frontend (used for CORS + email links) ---
FRONTEND_URL=http://localhost:5173

# --- MongoDB (use a free Atlas cluster or local mongod) ---
MONGODB_URI=mongodb://localhost:27017/authly

# --- Redis (use Upstash for free TLS or local redis) ---
# Format: redis://USER:PASS@HOST:PORT  or  rediss://USER:PASS@HOST:PORT for TLS
REDIS_URL=redis://localhost:6379

# --- SMTP (Gmail with an app password works out of the box) ---
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-gmail-app-password

# --- JWT secrets ---
# IMPORTANT: generate strong, DIFFERENT 64-byte hex values.
# Run: npm run gen-secrets   (prints two ready-to-paste values)
JWT_SECRET=replace-me-with-64-bytes-of-hex
REFRESH_SECRET=replace-me-with-a-DIFFERENT-64-bytes-of-hex
