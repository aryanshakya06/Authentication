# =============================================================================
# Authly · Frontend environment template
# =============================================================================
# Copy this file to frontend/.env and fill in real values.
#   cp frontend/.env.example frontend/.env
#
# Vite only reads variables prefixed with VITE_, and they are baked into the
# JavaScript bundle at build time. That means anything here is PUBLIC. Never
# put secrets, API keys, or anything sensitive in this file. Real secrets
# belong in backend/.env, where they stay server-side.
# =============================================================================


# Base URL of the backend API. No trailing slash.
# In production set this to your deployed API origin, e.g.
#   https://api.yourdomain.com
VITE_API_URL=http://localhost:5000

# Brand name shown in the navbar, page titles and footer.
VITE_APP_NAME=Authly
